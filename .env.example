# Rosser 全栈部署环境变量模板
# 复制为 .env 后按需修改

# 后端认证 Token（生产环境请务必修改）
ROSSER_TOKEN=change-me

# 后端服务监听地址与端口
ROSSER_HOST=0.0.0.0
ROSSER_PORT=8000

# 允许跨域访问后端的来源（前端/移动端部署地址，逗号分隔）
# 默认已包含独立入口 8001/8002 以及统一接入点 8003 的常用地址
# ROSSER_CORS_ORIGINS=http://127.0.0.1:8001,http://localhost:8002,http://127.0.0.1:8002,http://localhost:8003,http://127.0.0.1:8003
ROSSER_CORS_ORIGINS=*

# 前端、移动端独立入口，以及统一接入点的宿主机暴露端口
ROSSER_FRONTEND_PORT=8001
ROSSER_MOBILE_PORT=8002
ROSSER_PROXY_PORT=8003

# 数据持久化目录（由 docker-compose.yml 固定挂载，通常无需修改）
# ROSSER_DATA_DIR=./data
# ROSSER_STORAGE_DIR=./storage
